			"default": "./dist/index.js"
		}
	},
	"license": "Apache-2.0",
	"homepage": "https://github.com/saazip/cache-core#readme",
	"bugs": {
		"url": "https://github.com/saazip/cache-core/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saazip/cache-core.git",
		"directory": "packages/sdk"
	},
	"keywords": [
		"cache",
		"redis",
		"saas",
		"typescript",
		"backend"
	],
	"dependencies": {
		"@saazip/cache-core-contracts": "0.1.0",
		"@saazip/cache-core-domain": "0.1.0",
