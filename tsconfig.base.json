{
	"compilerOptions": {
		"target": "ES2024",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2024", "DOM"],
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"types": ["node"],
		"paths": {
			"@fengsoft/cache-core": ["./packages/sdk/src/index.ts"],
			"@fengsoft/cache-core-domain": ["./packages/core/src/index.ts"],
			"@fengsoft/cache-core-contracts": ["./packages/contracts/src/index.ts"],
			"@fengsoft/cache-core-metrics": ["./packages/metrics/src/index.ts"],
			"@fengsoft/cache-core-observability": [
				"./packages/observability/src/index.ts"
			],
			"@fengsoft/cache-core-testing": ["./packages/testing/src/index.ts"],
			"@fengsoft/cache-core-adapter-redis": [
				"./packages/adapters/redis/src/index.ts"
			]
		}
	}
}
